{
  "expo": {
    "name": "WaGraph",
    "slug": "wagraph",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080C18",

    "icon": "./assets/logo.png",

    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080C18"
    },

    "assetBundlePatterns": ["**/*"],

    "newArchEnabled": true,

    "ios": {
      "bundleIdentifier": "com.wagraph.app",
      "supportsTablet": false,
      "requireFullScreen": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "WaGraph needs access to save generated images to your photo library.",
        "NSPhotoLibraryAddUsageDescription": "WaGraph needs access to save generated images to your photo library.",
        "UIStatusBarStyle": "UIStatusBarStyleLightContent"
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },

    "android": {
      "package": "com.wagraph.app",
      "versionCode": 1,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "monochromeImage": "./assets/logo.png",
        "backgroundColor": "#080C18"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },

    "web": {
      "favicon": "./assets/logo.png",
      "bundler": "metro"
    },

    "scheme": "wagraph",

    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080C18",
          "image": "./assets/logo.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#080C18",
            "image": "./assets/logo.png"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-eas-project-id-here"
      }
    }
  }
}