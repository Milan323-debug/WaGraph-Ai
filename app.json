{
  "expo": {
    "name": "WaGraph",
    "slug": "wagraph",
    "version": "1.0.0",
    "owner": "senku212134",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080C18",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#080C18"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.wagraph.app",
      "supportsTablet": false,
      "requireFullScreen": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "WaGraph needs access to save generated images to your photo library.",
        "NSPhotoLibraryAddUsageDescription": "WaGraph needs access to save generated images to your photo library.",
        "UIStatusBarStyle": "UIStatusBarStyleLightContent"
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wagraph.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "monochromeImage": "./assets/logo.png",
        "backgroundColor": "#080C18"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/logo.png",
      "bundler": "metro"
    },
    "scheme": "wagraph",
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-media-library",
        {
          "photosPermission": "WaGraph needs access to save your generated images.",
          "savePhotosPermission": "WaGraph needs access to save your generated images.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080C18",
          "image": "./assets/logo.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#080C18",
            "image": "./assets/logo.png"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "usesCleartextTraffic": false,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "97ea9907-9bce-445e-a560-9b42953eb47b"
      }
    }
  }
}
